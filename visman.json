{
  "vm_state": {
    "score": 0
  },
  "templates": [
    {
      "id": "asteroid-small-template",
      "type": "circle",
      "size": {
        "radius": 10
      },
      "style": {
        "fillStyle": "#888888",
        "strokeStyle": "#FFFFFF",
        "lineWidth": 1
      },
      "physics": {
        "kinematic": true,
        "bodyType": "dynamic",
        "wrapEdges": true
      },
      "collision": {
        "collisionGroups": [
          "asteroids"
        ],
        "collidesWith": [
          "bullets",
          "player"
        ],
        "onCollision": "break_small"
      },
      "actions": {
        "break_small": {
          "destroy": true,
          "playSound": "assets/audio/drumkit/tr909_detroit/kick.wav",
          "stateMutations": [
            {
              "path": "vm.score",
              "operation": "increment",
              "value": 100
            }
          ]
        }
      }
    },
    {
      "id": "asteroid-medium-template",
      "type": "circle",
