  "canvasLayer": [
    {
      "id": "player",
      "context": "canvas",
      "type": "polygon",
      "position": {
        "x": 385,
        "y": 285
      },
      "rotation": {
        "z": -1.5708
      },
      "size": {
        "width": 30,
        "height": 24
      },
      "properties": {
        "points": [
          {
            "x": 15,
            "y": 0
          },
          {
            "x": -15,
            "y": -12
          },
          {
            "x": -15,
            "y": 12
          }
        ]
      },
      "style": {
        "fillStyle": "#00FF00",
        "strokeStyle": "#FFFFFF",
        "lineWidth": 2
      },
      "physics": {
        "kinematic": true,
        "bodyType": "dynamic",
        "wrapEdges": true,
        "fixedRotation": true,
        "friction": 0.02,
        "vx": 0,
        "vy": 0
      },
      "collision": {
        "collisionGroups": [
          "player"
        ],
        "collidesWith": [
          "asteroids"
        ],
        "onCollision": "die"
      },
      "actions": {
        "rotate_left": {
          "rotation": {
            "delta": {
              "z": -0.15
            }
          }
        },
        "rotate_right": {
          "rotation": {
            "delta": {
              "z": 0.15
            }
          }
        },
        "thrust_forward": {
          "thrust": {
            "speed": 15,
            "maxSpeed": 300
          }
        },
        "shoot": {
          "spawn": {
            "template": {
              "id": "bullet-template",
              "type": "circle",
              "context": "canvas",
              "size": {
                "radius": 4
              },
              "style": {
                "fillStyle": "#FFFF00",
                "strokeStyle": "#FFFF00",
                "lineWidth": 1
              },
              "physics": {
                "kinematic": true,
                "bodyType": "dynamic",
                "destroyOutOfBounds": true
              },
              "collision": {
                "collisionGroups": [
                  "bullets"
                ],
                "collidesWith": [
                  "asteroids"
                ],
                "onCollision": "destroy_self",
                "triggerOnce": true
              },
              "actions": {
                "destroy_self": {
                  "destroy": true
                }
              }
            },
            "speed": 420,
            "velocityRelativeToRotation": true,
            "offset": {
              "x": 15,
              "y": 0
            },
            "offsetFrom": "center"
          }
        },
        "die": {
          "destroy": true,
          "playSound": "assets/sounds/explosion.mp3"
        }
      },
      "callbacks": {
        "onKeyHeld": {
          "ArrowLeft": "rotate_left",
          "ArrowRight": "rotate_right",
          "ArrowUp": "thrust_forward"
        },
        "onKeyDown": {
          "Space": "shoot"
        },
        "onCollision": "die"
      }
    },
